[Unit]
Description=GPUbk usage monitor
After=default.target

[Service]
Type=simple
@SERVICE_ENVIRONMENT@
ExecStart=@PYTHON_EXECUTABLE@ -m bk monitor --interval 2 --rollup 60
Restart=on-failure
RestartPreventExitStatus=75
RestartSec=5
Nice=10
IOSchedulingClass=idle
NoNewPrivileges=true

[Install]
WantedBy=default.target
